{
  "compilerOptions": {
    // Strict TypeScript - Pillar 1
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "*": [
        "node_modules/*",
        "../../node_modules/*" 
      ]
    },
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    
    // Maximum strictness
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    
    // Emission
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    
    // Decorators for Lit
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    
    // Interoperability
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "vite-env.d.ts",
    "commitlint.config.cjs",
    ".husky/**/*",
    "vite.config.ts",
    "src/**/*.test.ts", 
    "tests/**/*.ts",
    "**/*.test.ts",
    "src/**/*.spec.ts","../../.config/lib-button.test.ts" ,   "src/**/*.stories.ts",
    "models/**/*", "architecture/base-components/lib-list.model.ts", "../../apps/app-react/src/custom-elements.d.ts",
    "src/**/*.stories.ts", "src/**/*.component.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
