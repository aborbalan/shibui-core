{
  "name": "@shibui-ui/ui",
  "version": "1.0.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/aborbalan/shibui-core",
    "directory": "packages/shibui-ui"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Librería UI agnóstica construida con Web Components y Lit | CDD",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./angular": {
      "types": "./dist/angular/index.d.ts",
      "import": "./dist/angular/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/shibui-elements.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": "./dist/tokens.css",
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "clean": "rimraf dist node_modules/.cache",
    "pack:local": "npm run build && npm pack",
    "preview": "vite preview",
    "prebuild": "npm run clean",
    "postbuild": "npm run type-check",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --config .config/eslintrc.cjs --ignore-path .config/.eslintignore",
    "stylelint": "stylelint --config .config/.stylelintrc.json --fix",
    "stylelint:staged": "stylelint --config .config/.stylelintrc.json --fix --",
    "format": "prettier --write \"src/**/*.ts\" --config .config/.prettierrc.json",
    "start": "npm run dev",
    "s": "npm run dev",
    "prepare": "node -e \"if (process.env.CI !== 'true') { try { require('child_process').execSync('husky', {stdio: 'inherit'}) } catch (e) {} }\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lighthouse": "lhci autorun --config=./.config/lighthouserc.cjs",
    "analyze": "cem analyze --litelement --exclude dist",
    "generate:wrappers": "tsx scripts/generate-wrappers.ts",
    "build": "npm run clean && vite build && tsc &&  npm run analyze && npm run generate:wrappers",
    "deploy": "npx firebase-tools deploy --only hosting:storybook --project lib-ui-b67c5"
  },
  "keywords": [
    "web-components",
    "lit",
    "ui-library",
    "agnostic",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@chromatic-com/storybook": "^5.0.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.49.0",
    "@storybook/addon-a11y": "^10.2.6",
    "@storybook/addon-docs": "^10.2.6",
    "@storybook/addon-vitest": "^10.2.6",
    "@storybook/web-components-vite": "^10.2.6",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.56.0",
    "eslint-plugin-storybook": "^10.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "lit": "^3.0.0",
    "playwright": "^1.49.0",
    "prettier": "^3.1.1",
    "sass": "^1.97.3",
    "storybook": "^10.2.6",
    "stylelint": "^17.1.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18",
    "firebase-tools": "^13.0.0"
  },
  "dependencies": {
    "@lit/react": "^1.0.8",
    "@phosphor-icons/core": "^2.1.1"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --config .config/eslintrc.cjs --fix --max-warnings=2"
    ]
  },
  "customElements": "dist/custom-elements.json"
}
