{
  "compilerOptions": {
    "target": "ESNext",
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler", /* O 'node' si usas versiones antiguas */
    "outDir": "./dist",
    "jsx": "react-jsx",
    "emitDeclarationOnly": false,
    "strict": true,
    "skipLibCheck": true, /* Importante para evitar conflictos entre tipos de React y Lit */
    "paths": {
      "@shibui/ui/react": ["../../packages/shibui-ui/dist/react/index.ts"],
      "@shibui/ui": ["../../packages/shibui-ui/dist/index.d.ts"]
       }
  },
  "include": [
    "src", 
    "src/custom-elements.d.ts", "src/vite-env.d.ts" // <--- RUTA DIRECTA AL FICHERO
  ],
  "exclude": ["node_modules", "dist"]
}