  "info": {
    "title": "Shibui UI API",
    "description": "REST API for the Shibui UI component library. Provides access to components, categories, examples and users.",
    "version": "1.0.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "categories",
      "description": "Component categories and navigation structure"
    },
    {
      "name": "components",
      "description": "Web components built with Lit"
    },
    {
      "name": "examples",
      "description": "Usage examples for each component"
    },
    {
      "name": "users",
      "description": "User management"
    }
  ],
  "servers": [],
  "components": {
    "schemas": {
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@shibui.dev"
          },
          "name": {
            "type": "string",
            "example": "Shibui Admin",
            "maxLength": 100
          },
          "avatarUrl": {
            "type": "string",
            "example": "https://api.dicebear.com/7.x/avataaars/svg?seed=admin"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "contributor",
              "viewer"
            ],
            "example": "contributor"
          }
        },
        "required": [
          "email",
          "name",
          "role"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {}
      },
      "CreateComponentDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Button",
            "maxLength": 100
          },
          "slug": {
            "type": "string",
            "example": "shibui-button",
            "maxLength": 100,
            "description": "URL-friendly kebab-case identifier"
          },
          "tagName": {
            "type": "string",
            "example": "shibui-button",
            "maxLength": 100,
            "description": "Custom element tag name"
          },
          "description": {
            "type": "string",
            "example": "A versatile button component supporting multiple variants and states.",
            "maxLength": 500
          },
          "version": {
            "type": "string",
            "example": "1.0.0",
            "description": "Semver version"
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "stable",
              "deprecated"
            ],
            "example": "stable"
          },
          "categoryId": {
            "type": "string",
            "example": "cat-0001-0000-0000-000000000001",
            "description": "Category UUID"
          },
          "packageName": {
            "type": "string",
            "example": "@shibui-ui/components",
            "maxLength": 150
          },
          "tags": {
            "example": [
              "form",
              "interactive",
              "accessible"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "docsUrl": {
            "type": "string",
            "example": "https://shibui.dev/docs/button"
          }
        },
        "required": [
          "name",
          "slug",
          "tagName",
          "description",
          "version",
          "status",
          "categoryId"
        ]
      },
      "UpdateComponentDto": {
        "type": "object",
        "properties": {}
      },
      "CreateCategoryDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Inputs & Forms",
            "maxLength": 80
          },
          "slug": {
            "type": "string",
            "example": "inputs-forms",
            "maxLength": 80,
            "description": "URL-friendly kebab-case identifier"
          },
          "description": {
            "type": "string",
            "example": "Text fields, selects and all form-related components.",
            "maxLength": 300
          },
          "icon": {
            "type": "string",
            "example": "form",
            "maxLength": 50,
            "description": "Icon name from the icon set"
          },
          "order": {
            "type": "number",
            "example": 0,
            "minimum": 0,
            "description": "Display order in sidebar navigation"
          }
        },
        "required": [
          "name",
          "slug",
          "order"
        ]
      },
      "UpdateCategoryDto": {
        "type": "object",
        "properties": {}
      },
      "CreateExampleDto": {
        "type": "object",
        "properties": {
          "componentId": {
            "type": "string",
            "example": "cmp-0001-0000-0000-000000000001",
            "description": "Component UUID"
          },
          "title": {
            "type": "string",
            "example": "Basic usage",
            "maxLength": 120
          },
          "description": {
            "type": "string",
            "example": "Default button with primary variant.",
            "maxLength": 400
          },
          "code": {
            "type": "string",
            "example": "<shibui-button variant=\"primary\">Click me</shibui-button>",
            "description": "Source code snippet"
          },
          "framework": {
            "type": "string",
            "enum": [
              "vanilla",
              "angular",
              "react",
              "vue"
            ],
            "example": "vanilla"
          },
          "order": {
            "type": "number",
            "example": 0,
            "minimum": 0,
            "description": "Display order within component examples"
          },
          "isDefault": {
            "type": "boolean",
            "example": true,
            "description": "Whether this is the primary example shown by default"
          }
        },
        "required": [
          "componentId",
          "title",
          "code",
          "framework",
          "order"
        ]
      },
      "UpdateExampleDto": {
        "type": "object",
        "properties": {}
      }
    }
  }
}